{
  "format_on_save": "on",
  "formatter": {
    "language_server": {
      "name": "biome"
    }
  },
  "code_actions_on_format": {
    "source.organizeImports.biome": true,
    "source.fixAll.biome": true
  },
  "lsp": {
    "biome": {
      "settings": {
        "require_config_file": true
      }
    }
  },
  "languages": {
    "CSS": {
      "code_actions_on_format": {
        "source.fixAll.stylelint": true
      }
    },
    "SCSS": {
      "code_actions_on_format": {
        "source.fixAll.stylelint": true
      }
    }
  }
}
