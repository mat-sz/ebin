{
  "name": "ebin-workspace",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "yarn workspace ebin run build",
    "test": "yarn workspace ebin run test",
    "bench": "yarn build && yarn workspace ebin-benchmark run bench",
    "profile": "yarn build && yarn workspace ebin-benchmark run profile",
    "lint": "npx @biomejs/biome check --write --no-errors-on-unmatched --files-ignore-unknown=true --colors=off --max-diagnostics=50 ."
  },
  "packageManager": "yarn@4.9.2",
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "lefthook": "^2.1.6",
    "vitest": "^3.2.4"
  }
}
